{
  "mcpServers": {
    "angular-cli": {
      "command": "npx",
      "args": [
        "-y",
        "@angular/cli",
        "mcp"
      ]
    },
    "vitest": {
      "command": "npx",
      "args": [
        "-y",
        "@djankies/vitest-mcp"
      ],
      "type": "stdio"
    },
    "spartan-ng-mcp-server": {
      "command": "npx",
      "args": [
        "-y",
        "spartan-ng-mcp-server"
      ],
      "type": "stdio"
    },
    "fallow": {
      "command": "fallow-mcp",
      "args": []
    }
  }
}