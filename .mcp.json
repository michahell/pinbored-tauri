{
  "mcpServers": {
    "angular-cli": {
      "command": "npx",
      "args": ["-y", "@angular/cli", "mcp"]
    },
    "vitest": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@djankies/vitest-mcp"],
      "env": {}
    },
    "spartan-ng-mcp-server": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "spartan-ng-mcp-server"]
    },
    "fallow": {
      "command": "fallow-mcp"
    }
  }
}
