{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "http:default",
    {
      "identifier": "http:default",
      "allow": [
        {
          "url": "http*://*"
        }
      ],
      "deny": [
        {
          "url": "https://private.tauri.app"
        }
      ]
    },
    "store:default",
    "dialog:default",
    "sql:default",
    "sql:allow-execute",
    "fs:default",
    {
      "identifier": "fs:scope",
      "allow": [
        {
          "path": "$APPDATA/databases/*"
        }
      ]
    },
    "fs:allow-app-write",
    "fs:allow-home-read-recursive",
    "fs:allow-home-write-recursive",
    "os:default"
  ]
}