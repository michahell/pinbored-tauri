{
  "compileOnSave": false,
  "compilerOptions": {
    "strict": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "preserve",
    "paths": {
      "@auth/*": ["./src/app/shared/auth/*"],
      "@components/*": ["./src/app/shared/components/*"],
      "@core/*": ["./src/app/shared/core/*"],
      "@data-providers/*": ["./src/app/shared/data-providers/*"],
      "@models/*": ["./src/app/shared/models/*"],
      "@services/*": ["./src/app/shared/services/*"],
      "@styles/*": ["./src/app/styles/*"],
      "@spartan-ng/helm/badge": ["./libs/ui/badge/src/index.ts"],
      "@spartan-ng/helm/button": ["./libs/ui/button/src/index.ts"],
      "@spartan-ng/helm/icon": ["./libs/ui/icon/src/index.ts"],
      "@spartan-ng/helm/item": ["./libs/ui/item/src/index.ts"],
      "@spartan-ng/helm/kbd": ["./libs/ui/kbd/src/index.ts"],
      "@spartan-ng/helm/menubar": ["./libs/ui/menubar/src/index.ts"],
      "@spartan-ng/helm/pagination": ["./libs/ui/pagination/src/index.ts"],
      "@spartan-ng/helm/utils": ["./libs/ui/utils/src/index.ts"],
      "@spartan-ng/helm/separator": ["./libs/ui/separator/src/index.ts"],
      "@spartan-ng/helm/dropdown-menu": ["./libs/ui/dropdown-menu/src/index.ts"],
      "@spartan-ng/helm/select": ["./libs/ui/select/src/index.ts"],
      "@spartan-ng/helm/table": ["./libs/ui/table/src/index.ts"],
      "@spartan-ng/helm/checkbox": ["./libs/ui/checkbox/src/index.ts"],
      "@spartan-ng/helm/label": ["./libs/ui/label/src/index.ts"],
      "@spartan-ng/helm/spinner": ["./libs/ui/spinner/src/index.ts"],
      "@spartan-ng/helm/card": ["./libs/ui/card/src/index.ts"],
      "@spartan-ng/helm/input": ["./libs/ui/input/src/index.ts"],
      "@spartan-ng/helm/field": ["./libs/ui/field/src/index.ts"],
      "@spartan-ng/helm/command": ["./libs/ui/command/src/index.ts"],
      "@spartan-ng/helm/navigation-menu": ["./libs/ui/navigation-menu/src/index.ts"],
      "@spartan-ng/helm/tabs": ["./libs/ui/tabs/src/index.ts"],
      "@spartan-ng/helm/button-group": ["./libs/ui/button-group/src/index.ts"],
      "@spartan-ng/helm/typography": ["./libs/ui/typography/src/index.ts"],
      "@spartan-ng/helm/breadcrumb": ["./libs/ui/breadcrumb/src/index.ts"],
      "@spartan-ng/helm/textarea": ["./libs/ui/textarea/src/index.ts"],
      "@spartan-ng/helm/accordion": ["./libs/ui/accordion/src/index.ts"],
      "@spartan-ng/helm/autocomplete": ["./libs/ui/autocomplete/src/index.ts"],
      "@spartan-ng/helm/popover": ["./libs/ui/popover/src/index.ts"],
      "@spartan-ng/helm/sheet": ["./libs/ui/sheet/src/index.ts"],
      "@spartan-ng/helm/input-group": ["./libs/ui/input-group/src/index.ts"],
      "@spartan-ng/helm/dialog": ["./libs/ui/dialog/src/index.ts"],
      "@spartan-ng/helm/alert-dialog": ["./libs/ui/alert-dialog/src/index.ts"]
    }
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "typeCheckHostBindings": true,
    "strictTemplates": true
  },
  "references": [
    {
      "path": "./tsconfig.app.json"
    },
    {
      "path": "./tsconfig.spec.json"
    }
  ]
}
